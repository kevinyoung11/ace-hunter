<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.kevinyoung.ace-hunter.collect-x</string>
  <key>ProgramArguments</key>
  <array>
    <string>__ACE_HUNTER_SCHEDULED_WRAPPER__</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>StartInterval</key>
  <integer>21600</integer>
  <key>ProcessType</key>
  <string>Background</string>
  <key>StandardOutPath</key>
  <string>__ACE_HUNTER_LOG_DIR__/collect-x.log</string>
  <key>StandardErrorPath</key>
  <string>__ACE_HUNTER_LOG_DIR__/collect-x.error.log</string>
</dict>
</plist>
